---
import Base from '../layouts/Base.astro'
import GameCard from '../components/GameCard.astro'
import games from '../content/games.json'

const latestGame = games[games.length - 1]
const sortedGames = [...games].reverse()
---
<Base title="100 Games in 100 Dagen">
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 pt-16 pb-12 text-center">
    <h1 class="font-[Bangers] text-6xl md:text-8xl text-yellow tracking-wider" style="text-shadow: 4px 4px 0 #FF6B35, 6px 6px 0 #E84393;">
      100 Games
    </h1>
    <p class="font-[Bangers] text-3xl md:text-4xl text-teal mt-2">in 100 Dagen</p>
    <p class="font-[Inter] text-lg text-light/70 mt-6 max-w-xl mx-auto leading-relaxed">
      Elke dag ontwerpt en bouwt AI een nieuw browserspel. Geen templates, geen herhalingen —
      puur creatieve automatisering. Speel ze allemaal, gratis.
    </p>
    <div class="mt-8 flex gap-4 justify-center">
      <a href={latestGame.playUrl} class="bg-orange hover:bg-yellow text-dark font-bold px-6 py-3 rounded-lg transition-colors font-[Inter]">
        Speel het nieuwste spel
      </a>
      <a href="/games" class="border border-light/30 hover:border-teal text-light/80 hover:text-teal px-6 py-3 rounded-lg transition-colors font-[Inter]">
        Alle games bekijken
      </a>
    </div>
  </section>

  <!-- Vandaag's game -->
  <section class="max-w-5xl mx-auto px-4 py-8">
    <h2 class="font-[Bangers] text-3xl text-light mb-6">
      Vandaag: Dag {latestGame.day}
    </h2>
    <div class="max-w-md">
      <GameCard {...latestGame} />
    </div>
  </section>

  <!-- Recente games -->
  {sortedGames.length > 1 && (
    <section class="max-w-5xl mx-auto px-4 py-8">
      <h2 class="font-[Bangers] text-3xl text-light mb-6">Eerdere games</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedGames.slice(1, 7).map(game => (
          <GameCard {...game} />
        ))}
      </div>
      {sortedGames.length > 7 && (
        <div class="text-center mt-8">
          <a href="/games" class="text-teal hover:text-orange transition-colors font-[Inter]">
            Bekijk alle {games.length} games
          </a>
        </div>
      )}
    </section>
  )}

  <!-- CTA -->
  <section class="max-w-3xl mx-auto px-4 py-16 text-center">
    <div class="bg-light/5 border border-light/10 rounded-2xl p-8">
      <h2 class="font-[Bangers] text-3xl text-yellow mb-4">Wat kan AI voor jou bouwen?</h2>
      <p class="font-[Inter] text-light/70 leading-relaxed mb-6">
        Dit project laat zien wat er mogelijk is met AI. Elke game — van concept tot werkend product —
        is ontworpen en gebouwd door AI in een sessie. Benieuwd wat dit voor jouw bedrijf kan betekenen?
      </p>
      <a href="https://perceptum.nl/contact" class="inline-block bg-teal hover:bg-orange text-dark font-bold px-8 py-3 rounded-lg transition-colors font-[Inter]">
        Praat met Perceptum
      </a>
    </div>
  </section>
</Base>
